{
  "compilerOptions": {
    "target": "es2015",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "@kitajs/html",
    "plugins": [{ "name": "@kitajs/ts-html-plugin" }],
    "paths": {
      "@models/*": ["./models/*"],
      "@components/*": ["./components/*"],
      "@utils/*": ["./utils/*"],
      "@services/*": ["./services/*"],
      "@hooks/*": ["./hooks/*"],
      "@pages/*": ["./pages/*"],
      "@styles/*": ["./styles/*"],
      "@assets/*": ["./assets/*"],
      "@config/*": ["./config/*"],
      "@repositories/*": ["./repositories/*"],
      "@store/*": ["./store/*"],
      "@layouts/*": ["./layouts/*"]
    }
  }
}
